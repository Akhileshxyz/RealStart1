# Application
PROJECT_NAME=RealStart Auth
DEBUG=False
API_V1_STR=/api/v1

# Security - IMPORTANT: Change these values!
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_MINIMUM_64_CHARACTERS_LONG
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB - Update this with your MongoDB connection string
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&ssl=true
DATABASE_NAME=realstart_db

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Server
HOST=0.0.0.0
PORT=8000

# CORS - Add your frontend domains
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration (for email verification and notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Mappls (MapmyIndia) API Configuration
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=
MAPPLS_BASE_URL=https://atlas.mappls.com/api
MAPPLS_AUTH_URL=https://outpost.mapmyindia.com/api/security/oauth/token

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_CACHE=True
REDIS_CACHE_TTL_DEFAULT=300
REDIS_CACHE_TTL_USER=600
REDIS_CACHE_TTL_PUBLIC=3600
REDIS_CACHE_TTL_LANDMARKS=21600
